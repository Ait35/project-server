//     "data" : {
//         "time_on": "19:00:00",
//         "time_off": "06:00:00"
//     }
// }                                       
// if success response (json) is /patch_config/token/1 
// {"message":"Config updated successfully","time_on":"19:00:00","time_off":"06:00:00"}


